      <bpmn:incoming>F_P2ParRH</bpmn:incoming>
      <bpmn:outgoing>F_J2ParRH</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerRev_P2" name="Parecer de Revisao">
      <bpmn:incoming>F_P2ParRev</bpmn:incoming>
      <bpmn:outgoing>F_J2ParRev</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerRecons_P2" name="Parecer Reconsideracao">
