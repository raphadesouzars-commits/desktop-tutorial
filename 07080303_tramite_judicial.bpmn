    <bpmn:sequenceFlow id="F_P2SupTec"   sourceRef="Gateway_Join_P2"      targetRef="Task_SupTecDiaco_P2" />
    <bpmn:sequenceFlow id="F_ToAprovaP2" sourceRef="Task_SupTecDiaco_P2"  targetRef="Task_AprovaInform_P2" />
