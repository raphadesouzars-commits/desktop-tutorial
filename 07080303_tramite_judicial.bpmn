    <!-- Lane Secac (P1) -->
    <bpmn:task id="Task_ConclusaoOC" name="Conclusao de Ocorrencia">
      <bpmn:incoming>F_P1_00</bpmn:incoming>
      <bpmn:outgoing>F_P1_01</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AberturaOC" name="Abertura OC - Representacao (fatos novos)">
      <bpmn:incoming>F_AberturaOC</bpmn:incoming>
      <bpmn:outgoing>F_EndNovaOC</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_NovaOC" name="Nova OC Aberta">
      <bpmn:incoming>F_EndNovaOC</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Lane Secac (P2) -->
    <bpmn:startEvent id="Start_P2" name="Demanda Juridica / Recurso / Notificacao Judicial">
      <bpmn:outgoing>F_P2_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_DemandaApoioJur" name="Demanda Apoio - Juridica (P2)">
      <bpmn:incoming>F_P2_01</bpmn:incoming>
      <bpmn:outgoing>F_P2_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_P2" name="Processo P2 Encerrado">
      <bpmn:incoming>F_P2End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Lane SeacoDiaco (P1) -->
    <bpmn:startEvent id="Start_P1" name="Processo com Decisao / Julgamento Externo Identificado">
      <bpmn:outgoing>F_P1_00</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_CoordSeaco" name="Coordenacao Seaco (P1)">
      <bpmn:incoming>F_P1_01</bpmn:incoming>
      <bpmn:outgoing>F_P1_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_P1" name="Encaminhamento">
      <bpmn:incoming>F_P1_02</bpmn:incoming>
      <bpmn:outgoing>F_P1_03</bpmn:outgoing>
      <bpmn:outgoing>F_ToParecerJul</bpmn:outgoing>
      <bpmn:outgoing>F_ToDespachoInstPAD</bpmn:outgoing>
      <bpmn:outgoing>F_ToDespachoInstPAR</bpmn:outgoing>
      <bpmn:outgoing>F_AberturaOC</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_EnvioPGFN" name="Envio para PGFN">
      <bpmn:incoming>F_P1_03</bpmn:incoming>
      <bpmn:outgoing>F_ToAcompanh</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerJul" name="Parecer de Julgamento">
      <bpmn:incoming>F_ToParecerJul</bpmn:incoming>
      <bpmn:outgoing>F_ToSupTec</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AcompanhaPendentes" name="Acompanha Processos Pendentes (judicial)">
      <bpmn:incoming>F_ToAcompanh</bpmn:incoming>
      <bpmn:outgoing>F_EndRetomada</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SupTecDiaco" name="Supervisao Tecnica Diaco">
      <bpmn:incoming>F_ToSupTec</bpmn:incoming>
      <bpmn:outgoing>F_ToAprovaParJul</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Retomada" name="Processo Aguardando Retomada">
      <bpmn:incoming>F_EndRetomada</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Lane SeacoDiaco (P2) -->
    <bpmn:task id="Task_CoordDiacoDemjur" name="Coordenacao DIACO/DEMJUR">
      <bpmn:incoming>F_P2_02</bpmn:incoming>
      <bpmn:outgoing>F_P2_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_P2" name="Tipo de Manifestacao">
      <bpmn:incoming>F_P2_03</bpmn:incoming>
      <bpmn:outgoing>F_P2InfJud</bpmn:outgoing>
