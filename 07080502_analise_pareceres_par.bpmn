<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_07080502"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Bizagi Modeler"
                  exporterVersion="1.0.0">

  <bpmn:collaboration id="Collaboration_07080502">
    <bpmn:participant id="Participant_Pool"
      name="07.08.05-02 - Analisar Processos PAR e Emitir Pareceres Tecnicos"
      processRef="Process_07080502" />
  </bpmn:collaboration>

  <bpmn:process id="Process_07080502" isExecutable="true">
    <bpmn:laneSet id="LaneSet_07080502">
      <bpmn:lane id="Lane_Secac" name="Secac">
        <bpmn:flowNodeRef>Task_AtualizaEpad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Inform</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Jul</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DiacoSeaco" name="Diaco / Seaco">
        <bpmn:flowNodeRef>Start_PAR2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CoordDiaco</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CoordSeaco</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TipoParecer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ParecerJul</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ParecerRec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ParecerRev</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ParecerCorr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JoinParecer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SupTecDiaco</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SupTec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReuniaoDiaco</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Subcorr" name="Subcorregedoria">
        <bpmn:flowNodeRef>Task_AprovaInform</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprovaParJul</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Lane Secac -->
    <bpmn:task id="Task_AtualizaEpad" name="ATUALIZA-EPAD-JAD/JUL/RECURSO">
      <bpmn:incoming>F_Atualiza1</bpmn:incoming>
      <bpmn:incoming>F_Atualiza2</bpmn:incoming>
      <bpmn:outgoing>F_AtualizaEnd1</bpmn:outgoing>
      <bpmn:outgoing>F_AtualizaEnd2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Inform" name="Processo Encerrado (Inform/Parecer)">
      <bpmn:incoming>F_AtualizaEnd1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Jul" name="Processo Encerrado (PAR-JUL/REC)">
      <bpmn:incoming>F_AtualizaEnd2</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Lane Diaco/Seaco -->
    <bpmn:startEvent id="Start_PAR2" name="PAR recebido para analise de parecer">
      <bpmn:outgoing>F_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_CoordDiaco" name="Coordenacao DIACO/DemJur - distribuicao e analise inicial PAR">
      <bpmn:incoming>F_01</bpmn:incoming>
      <bpmn:incoming>F_ReuniaBack</bpmn:incoming>
      <bpmn:outgoing>F_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CoordSeaco" name="Coord. Seaco - Analise e elaboracao de minuta de parecer">
      <bpmn:incoming>F_02</bpmn:incoming>
      <bpmn:outgoing>F_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_TipoParecer" name="Tipo de Parecer PAR" isMarkerVisible="true">
      <bpmn:incoming>F_03</bpmn:incoming>
      <bpmn:outgoing>F_TipoJul</bpmn:outgoing>
      <bpmn:outgoing>F_TipoRec</bpmn:outgoing>
      <bpmn:outgoing>F_TipoRev</bpmn:outgoing>
      <bpmn:outgoing>F_TipoCorr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ParecerJul" name="Elaborar Parecer de Julgamento PAR">
      <bpmn:incoming>F_TipoJul</bpmn:incoming>
      <bpmn:outgoing>F_JoinJul</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerRec" name="Elaborar Parecer de Reconsideracao PAR">
      <bpmn:incoming>F_TipoRec</bpmn:incoming>
      <bpmn:outgoing>F_JoinRec</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerRev" name="Elaborar Parecer de Revisao PAR">
      <bpmn:incoming>F_TipoRev</bpmn:incoming>
      <bpmn:outgoing>F_JoinRev</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerCorr" name="Elaborar Parecer Correcional PAR">
      <bpmn:incoming>F_TipoCorr</bpmn:incoming>
      <bpmn:outgoing>F_JoinCorr</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_JoinParecer" name="Parecer elaborado">
      <bpmn:incoming>F_JoinJul</bpmn:incoming>
      <bpmn:incoming>F_JoinRec</bpmn:incoming>
      <bpmn:incoming>F_JoinRev</bpmn:incoming>
      <bpmn:incoming>F_JoinCorr</bpmn:incoming>
      <bpmn:outgoing>F_SupTec</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SupTecDiaco" name="Supervisao Tecnica DIACO">
      <bpmn:incoming>F_SupTec</bpmn:incoming>
      <bpmn:outgoing>F_GwSupTec</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_SupTec" name="Qualidade OK?" isMarkerVisible="true">
      <bpmn:incoming>F_GwSupTec</bpmn:incoming>
      <bpmn:outgoing>F_SimInform</bpmn:outgoing>
      <bpmn:outgoing>F_SimParJul</bpmn:outgoing>
      <bpmn:outgoing>F_NaoReuniao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ReuniaoDiaco" name="REUNIAO-DIACO">
      <bpmn:incoming>F_NaoReuniao</bpmn:incoming>
      <bpmn:outgoing>F_ReuniaBack</bpmn:outgoing>
    </bpmn:task>

    <!-- Lane Subcorregedoria -->
    <bpmn:task id="Task_AprovaInform" name="Aprova Inform/Parecer">
      <bpmn:incoming>F_SimInform</bpmn:incoming>
      <bpmn:outgoing>F_Atualiza1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AprovaParJul" name="Aprova-PAR-JUL/REC">
      <bpmn:incoming>F_SimParJul</bpmn:incoming>
      <bpmn:outgoing>F_Atualiza2</bpmn:outgoing>
    </bpmn:task>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="F_01"          sourceRef="Start_PAR2"          targetRef="Task_CoordDiaco" />
    <bpmn:sequenceFlow id="F_02"          sourceRef="Task_CoordDiaco"     targetRef="Task_CoordSeaco" />
    <bpmn:sequenceFlow id="F_03"          sourceRef="Task_CoordSeaco"     targetRef="Gateway_TipoParecer" />
    <bpmn:sequenceFlow id="F_TipoJul"     sourceRef="Gateway_TipoParecer" targetRef="Task_ParecerJul" />
    <bpmn:sequenceFlow id="F_TipoRec"     sourceRef="Gateway_TipoParecer" targetRef="Task_ParecerRec" />
    <bpmn:sequenceFlow id="F_TipoRev"     sourceRef="Gateway_TipoParecer" targetRef="Task_ParecerRev" />
    <bpmn:sequenceFlow id="F_TipoCorr"    sourceRef="Gateway_TipoParecer" targetRef="Task_ParecerCorr" />
    <bpmn:sequenceFlow id="F_JoinJul"     sourceRef="Task_ParecerJul"     targetRef="Gateway_JoinParecer" />
    <bpmn:sequenceFlow id="F_JoinRec"     sourceRef="Task_ParecerRec"     targetRef="Gateway_JoinParecer" />
    <bpmn:sequenceFlow id="F_JoinRev"     sourceRef="Task_ParecerRev"     targetRef="Gateway_JoinParecer" />
    <bpmn:sequenceFlow id="F_JoinCorr"    sourceRef="Task_ParecerCorr"    targetRef="Gateway_JoinParecer" />
    <bpmn:sequenceFlow id="F_SupTec"      sourceRef="Gateway_JoinParecer" targetRef="Task_SupTecDiaco" />
    <bpmn:sequenceFlow id="F_GwSupTec"    sourceRef="Task_SupTecDiaco"    targetRef="Gateway_SupTec" />
    <bpmn:sequenceFlow id="F_SimInform"   sourceRef="Gateway_SupTec"      targetRef="Task_AprovaInform" />
    <bpmn:sequenceFlow id="F_SimParJul"   sourceRef="Gateway_SupTec"      targetRef="Task_AprovaParJul" />
    <bpmn:sequenceFlow id="F_NaoReuniao"  sourceRef="Gateway_SupTec"      targetRef="Task_ReuniaoDiaco" />
    <bpmn:sequenceFlow id="F_ReuniaBack"  sourceRef="Task_ReuniaoDiaco"   targetRef="Task_CoordDiaco" />
    <bpmn:sequenceFlow id="F_Atualiza1"   sourceRef="Task_AprovaInform"   targetRef="Task_AtualizaEpad" />
    <bpmn:sequenceFlow id="F_Atualiza2"   sourceRef="Task_AprovaParJul"   targetRef="Task_AtualizaEpad" />
    <bpmn:sequenceFlow id="F_AtualizaEnd1" sourceRef="Task_AtualizaEpad"  targetRef="End_Inform" />
    <bpmn:sequenceFlow id="F_AtualizaEnd2" sourceRef="Task_AtualizaEpad"  targetRef="End_Jul" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_07080502">
    <bpmndi:BPMNPlane id="BPMNPlane_07080502" bpmnElement="Collaboration_07080502">

      <!-- Pool: x=100, y=50, w=2000, h=660 -->
      <bpmndi:BPMNShape id="Participant_Pool_di" bpmnElement="Participant_Pool" isHorizontal="true">
        <dc:Bounds x="100" y="50" width="2000" height="660" />
      </bpmndi:BPMNShape>

      <!-- Lane Secac: y=50, h=130 -->
      <bpmndi:BPMNShape id="Lane_Secac_di" bpmnElement="Lane_Secac" isHorizontal="true">
        <dc:Bounds x="130" y="50" width="1970" height="130" />
      </bpmndi:BPMNShape>

      <!-- Lane DiacoSeaco: y=180, h=350 -->
      <bpmndi:BPMNShape id="Lane_DiacoSeaco_di" bpmnElement="Lane_DiacoSeaco" isHorizontal="true">
        <dc:Bounds x="130" y="180" width="1970" height="350" />
      </bpmndi:BPMNShape>

      <!-- Lane Subcorr: y=530, h=180 -->
      <bpmndi:BPMNShape id="Lane_Subcorr_di" bpmnElement="Lane_Subcorr" isHorizontal="true">
        <dc:Bounds x="130" y="530" width="1970" height="180" />
      </bpmndi:BPMNShape>

      <!-- Lane Secac elements (center y=115) -->
      <bpmndi:BPMNShape id="Task_AtualizaEpad_di" bpmnElement="Task_AtualizaEpad">
        <dc:Bounds x="1670" y="85" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Inform_di" bpmnElement="End_Inform">
        <dc:Bounds x="1850" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Jul_di" bpmnElement="End_Jul">
        <dc:Bounds x="1920" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Lane DiacoSeaco elements (lane center y=355) -->
      <!-- Start: x=165, y=337 -->
      <bpmndi:BPMNShape id="Start_PAR2_di" bpmnElement="Start_PAR2">
        <dc:Bounds x="165" y="337" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- CoordDiaco: x=240, y=325 -->
      <bpmndi:BPMNShape id="Task_CoordDiaco_di" bpmnElement="Task_CoordDiaco">
        <dc:Bounds x="240" y="325" width="140" height="60" />
      </bpmndi:BPMNShape>
      <!-- CoordSeaco: x=430, y=325 -->
      <bpmndi:BPMNShape id="Task_CoordSeaco_di" bpmnElement="Task_CoordSeaco">
        <dc:Bounds x="430" y="325" width="140" height="60" />
      </bpmndi:BPMNShape>
      <!-- Gateway_TipoParecer: x=625, y=335 -->
      <bpmndi:BPMNShape id="Gateway_TipoParecer_di" bpmnElement="Gateway_TipoParecer" isMarkerVisible="true">
        <dc:Bounds x="625" y="335" width="40" height="40" />
      </bpmndi:BPMNShape>

      <!-- 4 task branches at x=720, stacked y=195,255,315,375 (h=50 each) -->
      <bpmndi:BPMNShape id="Task_ParecerJul_di" bpmnElement="Task_ParecerJul">
        <dc:Bounds x="720" y="195" width="140" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ParecerRec_di" bpmnElement="Task_ParecerRec">
        <dc:Bounds x="720" y="255" width="140" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ParecerRev_di" bpmnElement="Task_ParecerRev">
        <dc:Bounds x="720" y="315" width="140" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ParecerCorr_di" bpmnElement="Task_ParecerCorr">
        <dc:Bounds x="720" y="375" width="140" height="50" />
      </bpmndi:BPMNShape>

      <!-- Gateway_JoinParecer: x=920, y=335 (center y=355, center of tasks range 220 to 400) -->
      <bpmndi:BPMNShape id="Gateway_JoinParecer_di" bpmnElement="Gateway_JoinParecer" isMarkerVisible="true">
        <dc:Bounds x="920" y="335" width="40" height="40" />
      </bpmndi:BPMNShape>

      <!-- SupTecDiaco: x=1010, y=325 -->
      <bpmndi:BPMNShape id="Task_SupTecDiaco_di" bpmnElement="Task_SupTecDiaco">
        <dc:Bounds x="1010" y="325" width="140" height="60" />
      </bpmndi:BPMNShape>

      <!-- Gateway_SupTec: x=1210, y=335 -->
      <bpmndi:BPMNShape id="Gateway_SupTec_di" bpmnElement="Gateway_SupTec" isMarkerVisible="true">
        <dc:Bounds x="1210" y="335" width="40" height="40" />
      </bpmndi:BPMNShape>

      <!-- ReuniaoDiaco: x=1290, y=430 -->
      <bpmndi:BPMNShape id="Task_ReuniaoDiaco_di" bpmnElement="Task_ReuniaoDiaco">
        <dc:Bounds x="1290" y="430" width="140" height="60" />
      </bpmndi:BPMNShape>

      <!-- Lane Subcorr elements (center y=620) -->
      <!-- AprovaInform: x=1430, y=570 -->
      <bpmndi:BPMNShape id="Task_AprovaInform_di" bpmnElement="Task_AprovaInform">
        <dc:Bounds x="1430" y="555" width="140" height="60" />
      </bpmndi:BPMNShape>
      <!-- AprovaParJul: x=1430, y=645 -->
      <bpmndi:BPMNShape id="Task_AprovaParJul_di" bpmnElement="Task_AprovaParJul">
        <dc:Bounds x="1430" y="635" width="140" height="60" />
      </bpmndi:BPMNShape>

      <!-- Edges -->

      <!-- Start → CoordDiaco -->
      <bpmndi:BPMNEdge id="F_01_di" bpmnElement="F_01">
        <di:waypoint x="201" y="355" />
        <di:waypoint x="240" y="355" />
      </bpmndi:BPMNEdge>

      <!-- CoordDiaco → CoordSeaco -->
      <bpmndi:BPMNEdge id="F_02_di" bpmnElement="F_02">
        <di:waypoint x="380" y="355" />
        <di:waypoint x="430" y="355" />
      </bpmndi:BPMNEdge>

      <!-- CoordSeaco → Gateway_TipoParecer -->
      <bpmndi:BPMNEdge id="F_03_di" bpmnElement="F_03">
        <di:waypoint x="570" y="355" />
        <di:waypoint x="625" y="355" />
      </bpmndi:BPMNEdge>

      <!-- Gateway_TipoParecer → 4 tasks -->
      <bpmndi:BPMNEdge id="F_TipoJul_di" bpmnElement="F_TipoJul">
        <di:waypoint x="645" y="335" />
        <di:waypoint x="645" y="220" />
        <di:waypoint x="720" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_TipoRec_di" bpmnElement="F_TipoRec">
        <di:waypoint x="645" y="335" />
        <di:waypoint x="645" y="280" />
        <di:waypoint x="720" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_TipoRev_di" bpmnElement="F_TipoRev">
        <di:waypoint x="645" y="375" />
        <di:waypoint x="645" y="340" />
        <di:waypoint x="720" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_TipoCorr_di" bpmnElement="F_TipoCorr">
        <di:waypoint x="645" y="375" />
        <di:waypoint x="645" y="400" />
        <di:waypoint x="720" y="400" />
      </bpmndi:BPMNEdge>

      <!-- 4 tasks → Gateway_JoinParecer -->
      <bpmndi:BPMNEdge id="F_JoinJul_di" bpmnElement="F_JoinJul">
        <di:waypoint x="860" y="220" />
        <di:waypoint x="940" y="220" />
        <di:waypoint x="940" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_JoinRec_di" bpmnElement="F_JoinRec">
        <di:waypoint x="860" y="280" />
        <di:waypoint x="940" y="280" />
        <di:waypoint x="940" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_JoinRev_di" bpmnElement="F_JoinRev">
        <di:waypoint x="860" y="340" />
        <di:waypoint x="920" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_JoinCorr_di" bpmnElement="F_JoinCorr">
        <di:waypoint x="860" y="400" />
        <di:waypoint x="940" y="400" />
        <di:waypoint x="940" y="375" />
      </bpmndi:BPMNEdge>

      <!-- Gateway_JoinParecer → SupTecDiaco -->
      <bpmndi:BPMNEdge id="F_SupTec_di" bpmnElement="F_SupTec">
        <di:waypoint x="960" y="355" />
        <di:waypoint x="1010" y="355" />
      </bpmndi:BPMNEdge>

      <!-- SupTecDiaco → Gateway_SupTec -->
      <bpmndi:BPMNEdge id="F_GwSupTec_di" bpmnElement="F_GwSupTec">
        <di:waypoint x="1150" y="355" />
        <di:waypoint x="1210" y="355" />
      </bpmndi:BPMNEdge>

      <!-- Gateway_SupTec → AprovaInform (Subcorr) -->
      <bpmndi:BPMNEdge id="F_SimInform_di" bpmnElement="F_SimInform">
        <di:waypoint x="1230" y="375" />
        <di:waypoint x="1230" y="585" />
        <di:waypoint x="1430" y="585" />
      </bpmndi:BPMNEdge>

      <!-- Gateway_SupTec → AprovaParJul (Subcorr) -->
      <bpmndi:BPMNEdge id="F_SimParJul_di" bpmnElement="F_SimParJul">
        <di:waypoint x="1250" y="355" />
        <di:waypoint x="1340" y="355" />
        <di:waypoint x="1340" y="665" />
        <di:waypoint x="1430" y="665" />
      </bpmndi:BPMNEdge>

      <!-- Gateway_SupTec → ReuniaoDiaco -->
      <bpmndi:BPMNEdge id="F_NaoReuniao_di" bpmnElement="F_NaoReuniao">
        <di:waypoint x="1230" y="375" />
        <di:waypoint x="1230" y="460" />
        <di:waypoint x="1290" y="460" />
      </bpmndi:BPMNEdge>

      <!-- ReuniaoDiaco → CoordDiaco (loop back) -->
      <bpmndi:BPMNEdge id="F_ReuniaBack_di" bpmnElement="F_ReuniaBack">
        <di:waypoint x="1290" y="490" />
        <di:waypoint x="310" y="490" />
        <di:waypoint x="310" y="385" />
      </bpmndi:BPMNEdge>

      <!-- AprovaInform → AtualizaEpad (Secac) -->
      <bpmndi:BPMNEdge id="F_Atualiza1_di" bpmnElement="F_Atualiza1">
        <di:waypoint x="1570" y="585" />
        <di:waypoint x="1740" y="585" />
        <di:waypoint x="1740" y="145" />
      </bpmndi:BPMNEdge>

      <!-- AprovaParJul → AtualizaEpad (Secac) -->
      <bpmndi:BPMNEdge id="F_Atualiza2_di" bpmnElement="F_Atualiza2">
        <di:waypoint x="1570" y="665" />
        <di:waypoint x="1760" y="665" />
        <di:waypoint x="1760" y="145" />
      </bpmndi:BPMNEdge>

      <!-- AtualizaEpad → End_Inform -->
      <bpmndi:BPMNEdge id="F_AtualizaEnd1_di" bpmnElement="F_AtualizaEnd1">
        <di:waypoint x="1810" y="115" />
        <di:waypoint x="1850" y="98" />
      </bpmndi:BPMNEdge>

      <!-- AtualizaEpad → End_Jul -->
      <bpmndi:BPMNEdge id="F_AtualizaEnd2_di" bpmnElement="F_AtualizaEnd2">
        <di:waypoint x="1810" y="115" />
        <di:waypoint x="1920" y="98" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
