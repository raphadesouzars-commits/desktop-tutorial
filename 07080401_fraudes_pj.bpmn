<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_07080401"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Bizagi Modeler"
                  exporterVersion="1.0.0">

  <bpmn:collaboration id="Collaboration_07080401">
    <bpmn:participant id="Participant_Pool"
      name="07.08.04-01 - Investigar Fraudes e Atos Lesivos Corporativos PJ"
      processRef="Process_07080401" />
  </bpmn:collaboration>

  <bpmn:process id="Process_07080401" isExecutable="true">
    <bpmn:laneSet id="LaneSet_07080401">

      <bpmn:lane id="Lane_Secac" name="Secac">
        <bpmn:flowNodeRef>Start_Ouvidoria</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_Representacao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AberturaOuv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AberturaRep</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Merge_OC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InstrucaoOC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AtualizaEpadOC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_To_Diaco</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Diaco" name="Diaco / Seaco">
        <bpmn:flowNodeRef>Task_Triagem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CoordDiaco</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ParecerAdm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DeliberacaoDiaco</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Arquivado</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Subcorregedoria" name="Subcorregedoria (Controle Independente)">
        <bpmn:flowNodeRef>Task_AprovaINV</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprovaPAR</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Divid" name="Divid (Divisao de Investigacao)">
        <bpmn:flowNodeRef>Task_CoordDivid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Split_Inv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_IPS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_INPRE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DINVE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Join_Inv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_GenDivid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GerenDivid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AtdDemDivid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_GenDivid</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_DProc" name="DProc">
        <bpmn:flowNodeRef>Task_InstauracaoPAR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CoordDProc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_PAR</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <!-- Lane Secac -->
    <bpmn:startEvent id="Start_Ouvidoria" name="Denuncia Ouvidoria">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="Start_Representacao" name="Representacao Oficial">
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AberturaOuv" name="Abertura OC - Ouvidoria">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AberturaRep" name="Abertura OC - Representacao">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Merge_OC">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_InstrucaoOC" name="Ocorrencia - Instrucao">
      <bpmn:incoming>Flow_S5</bpmn:incoming>
      <bpmn:outgoing>Flow_S6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AtualizaEpadOC" name="ATUALIZA-EPAD-OC">
      <bpmn:incoming>Flow_S6</bpmn:incoming>
      <bpmn:outgoing>Flow_S7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_To_Diaco">
      <bpmn:incoming>Flow_S7</bpmn:incoming>
      <bpmn:outgoing>Flow_S8</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Lane Diaco -->
    <bpmn:task id="Task_Triagem" name="Triagem SECAC / Ouvidoria">
      <bpmn:incoming>Flow_S8</bpmn:incoming>
      <bpmn:outgoing>Flow_S9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CoordDiaco" name="Coordenacao DIACO/DEMJUR">
      <bpmn:incoming>Flow_S9</bpmn:incoming>
      <bpmn:outgoing>Flow_S10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParecerAdm" name="Parecer Admissibilidade">
      <bpmn:incoming>Flow_To_Parecer</bpmn:incoming>
      <bpmn:outgoing>Flow_To_AprovaPAR</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DeliberacaoDiaco" name="Analyse / Deliberacao DIACO">
      <bpmn:incoming>Flow_To_Deliberacao</bpmn:incoming>
      <bpmn:outgoing>Flow_To_Decision</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Qual a Admissibilidade?">
      <bpmn:incoming>Flow_To_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_PAR</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Arq</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Arquivado" name="Processo Arquivado / Outro Orgao">
      <bpmn:incoming>Flow_Decision_Arq</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Lane Subcorregedoria -->
    <bpmn:task id="Task_AprovaINV" name="Acompanha/Aprova-INV">
      <bpmn:incoming>Flow_To_AprovaINV</bpmn:incoming>
      <bpmn:outgoing>Flow_To_Parecer</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AprovaPAR" name="Acompanha/Aprova-PAR.JAD">
      <bpmn:incoming>Flow_To_AprovaPAR</bpmn:incoming>
      <bpmn:outgoing>Flow_To_Deliberacao</bpmn:outgoing>
    </bpmn:task>

    <!-- Lane Divid — 3 fluxos investigativos em caixas simples -->
    <bpmn:task id="Task_CoordDivid" name="Coordenacao DIVID">
      <bpmn:incoming>Flow_S10</bpmn:incoming>
      <bpmn:outgoing>Flow_S11</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateway de divisão: define o rito investigativo -->
    <bpmn:exclusiveGateway id="Gateway_Split_Inv" name="Definicao do Rito">
      <bpmn:incoming>Flow_S11</bpmn:incoming>
      <bpmn:outgoing>Flow_To_IPS</bpmn:outgoing>
      <bpmn:outgoing>Flow_To_INPRE</bpmn:outgoing>
      <bpmn:outgoing>Flow_To_DINVE</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Os 3 fluxos investigativos como subprocessos colapsados -->
    <bpmn:subProcess id="SubProcess_IPS" name="IPS - Inquerito Preliminar Sindicante">
      <bpmn:incoming>Flow_To_IPS</bpmn:incoming>
      <bpmn:outgoing>Flow_From_IPS</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:subProcess id="SubProcess_INPRE" name="INPRE-PJ - Inquerito Preliminar PJ">
      <bpmn:incoming>Flow_To_INPRE</bpmn:incoming>
      <bpmn:outgoing>Flow_From_INPRE</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:task id="Task_DINVE" name="DINVE - Diligencia Investigativa Especial">
      <bpmn:incoming>Flow_To_DINVE</bpmn:incoming>
      <bpmn:outgoing>Flow_From_DINVE</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateway de convergência: os 3 fluxos apontam para cá -->
    <bpmn:exclusiveGateway id="Gateway_Join_Inv">
      <bpmn:incoming>Flow_From_IPS</bpmn:incoming>
      <bpmn:incoming>Flow_From_INPRE</bpmn:incoming>
      <bpmn:incoming>Flow_From_DINVE</bpmn:incoming>
      <bpmn:outgoing>Flow_To_AprovaINV</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fluxo paralelo independente: Demanda Interna Divid -->
    <bpmn:startEvent id="Start_GenDivid" name="Demanda Interna Divid / DILEX">
      <bpmn:outgoing>Flow_GD1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_GerenDivid" name="GEREN-DIVID - Gerenciamento das Atividades da Divid">
      <bpmn:incoming>Flow_GD1</bpmn:incoming>
      <bpmn:outgoing>Flow_GD2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AtdDemDivid" name="ATD-DEM-DIVID - Atendimento de Demandas da Divid">
      <bpmn:incoming>Flow_GD2</bpmn:incoming>
      <bpmn:outgoing>Flow_GD3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_GenDivid" name="Demanda Interna Encerrada">
      <bpmn:incoming>Flow_GD3</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Lane DProc -->
    <bpmn:task id="Task_InstauracaoPAR" name="Portaria de Instauracao PAR">
      <bpmn:incoming>Flow_Decision_PAR</bpmn:incoming>
      <bpmn:outgoing>Flow_To_CoordDProc</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CoordDProc" name="Coordenacao DPROC">
      <bpmn:incoming>Flow_To_CoordDProc</bpmn:incoming>
      <bpmn:outgoing>Flow_To_EndPAR</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_PAR" name="PAR Instaurado em Instrucao">
      <bpmn:incoming>Flow_To_EndPAR</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_S1"  sourceRef="Start_Ouvidoria"      targetRef="Task_AberturaOuv" />
    <bpmn:sequenceFlow id="Flow_S2"  sourceRef="Start_Representacao"  targetRef="Task_AberturaRep" />
    <bpmn:sequenceFlow id="Flow_S3"  sourceRef="Task_AberturaOuv"     targetRef="Gateway_Merge_OC" />
    <bpmn:sequenceFlow id="Flow_S4"  sourceRef="Task_AberturaRep"     targetRef="Gateway_Merge_OC" />
    <bpmn:sequenceFlow id="Flow_S5"  sourceRef="Gateway_Merge_OC"     targetRef="Task_InstrucaoOC" />
    <bpmn:sequenceFlow id="Flow_S6"  sourceRef="Task_InstrucaoOC"     targetRef="Task_AtualizaEpadOC" />
    <bpmn:sequenceFlow id="Flow_S7"  sourceRef="Task_AtualizaEpadOC"  targetRef="Gateway_To_Diaco" />
    <bpmn:sequenceFlow id="Flow_S8"  sourceRef="Gateway_To_Diaco"     targetRef="Task_Triagem" />
    <bpmn:sequenceFlow id="Flow_S9"  sourceRef="Task_Triagem"         targetRef="Task_CoordDiaco" />
    <bpmn:sequenceFlow id="Flow_S10" sourceRef="Task_CoordDiaco"      targetRef="Task_CoordDivid" />
    <bpmn:sequenceFlow id="Flow_S11" sourceRef="Task_CoordDivid"      targetRef="Gateway_Split_Inv" />
    <bpmn:sequenceFlow id="Flow_To_IPS"   sourceRef="Gateway_Split_Inv" targetRef="SubProcess_IPS" />
    <bpmn:sequenceFlow id="Flow_To_INPRE" sourceRef="Gateway_Split_Inv" targetRef="SubProcess_INPRE" />
    <bpmn:sequenceFlow id="Flow_To_DINVE" sourceRef="Gateway_Split_Inv" targetRef="Task_DINVE" />
    <bpmn:sequenceFlow id="Flow_From_IPS"   sourceRef="SubProcess_IPS"   targetRef="Gateway_Join_Inv" />
    <bpmn:sequenceFlow id="Flow_From_INPRE" sourceRef="SubProcess_INPRE" targetRef="Gateway_Join_Inv" />
    <bpmn:sequenceFlow id="Flow_From_DINVE" sourceRef="Task_DINVE"       targetRef="Gateway_Join_Inv" />
    <bpmn:sequenceFlow id="Flow_To_AprovaINV"   sourceRef="Gateway_Join_Inv"      targetRef="Task_AprovaINV" />
    <bpmn:sequenceFlow id="Flow_To_Parecer"     sourceRef="Task_AprovaINV"        targetRef="Task_ParecerAdm" />
    <bpmn:sequenceFlow id="Flow_To_AprovaPAR"   sourceRef="Task_ParecerAdm"       targetRef="Task_AprovaPAR" />
    <bpmn:sequenceFlow id="Flow_To_Deliberacao" sourceRef="Task_AprovaPAR"        targetRef="Task_DeliberacaoDiaco" />
    <bpmn:sequenceFlow id="Flow_To_Decision"    sourceRef="Task_DeliberacaoDiaco" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_Decision_PAR"   sourceRef="Gateway_Decision"      targetRef="Task_InstauracaoPAR" />
    <bpmn:sequenceFlow id="Flow_Decision_Arq"   sourceRef="Gateway_Decision"      targetRef="End_Arquivado" />
    <bpmn:sequenceFlow id="Flow_To_CoordDProc"  sourceRef="Task_InstauracaoPAR"   targetRef="Task_CoordDProc" />
    <bpmn:sequenceFlow id="Flow_To_EndPAR"      sourceRef="Task_CoordDProc"       targetRef="End_PAR" />
    <bpmn:sequenceFlow id="Flow_GD1" sourceRef="Start_GenDivid"   targetRef="Task_GerenDivid" />
    <bpmn:sequenceFlow id="Flow_GD2" sourceRef="Task_GerenDivid"  targetRef="Task_AtdDemDivid" />
    <bpmn:sequenceFlow id="Flow_GD3" sourceRef="Task_AtdDemDivid" targetRef="End_GenDivid" />
  </bpmn:process>

  <!--
    LAYOUT — coordenadas verificadas, sem sobreposições
    ─────────────────────────────────────────────────────
    Pool                : x=100  y=50   w=2000 h=1090
    Lane_Secac          : y=50   h=180  (y   50 –  230)
    Lane_Diaco          : y=230  h=170  (y  230 –  400)
    Lane_Subcorregedoria: y=400  h=160  (y  400 –  560)
    Lane_Divid          : y=560  h=370  (y  560 –  930)
      CoordDivid / Gateways  : y=630–700 (centro y=665)
      SubProcess_IPS    : y=575–655  (linha 1)
      SubProcess_INPRE  : y=665–745  (linha 2)  ← centro alinhado ao gateway
      Task_DINVE         : y=755–825  (linha 3)
      GenDivid flow      : y=855–925  (linha 4, separado à direita)
    Lane_DProc          : y=930  h=160  (y  930 – 1090)
  -->

  <bpmndi:BPMNDiagram id="BPMNDiagram_07080401">
    <bpmndi:BPMNPlane id="BPMNPlane_07080401" bpmnElement="Collaboration_07080401">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_Pool_di" bpmnElement="Participant_Pool" isHorizontal="true">
        <dc:Bounds x="100" y="50" width="2000" height="1090" />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Secac_di" bpmnElement="Lane_Secac" isHorizontal="true">
        <dc:Bounds x="130" y="50" width="1970" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Diaco_di" bpmnElement="Lane_Diaco" isHorizontal="true">
        <dc:Bounds x="130" y="230" width="1970" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Subcorregedoria_di" bpmnElement="Lane_Subcorregedoria" isHorizontal="true">
        <dc:Bounds x="130" y="400" width="1970" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Divid_di" bpmnElement="Lane_Divid" isHorizontal="true">
        <dc:Bounds x="130" y="560" width="1970" height="370" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_DProc_di" bpmnElement="Lane_DProc" isHorizontal="true">
        <dc:Bounds x="130" y="930" width="1970" height="160" />
      </bpmndi:BPMNShape>

      <!-- ── Lane Secac (y 50–230) ── -->
      <!-- Start_Ouvidoria    center (198, 114) -->
      <bpmndi:BPMNShape id="Start_Ouvidoria_di" bpmnElement="Start_Ouvidoria">
        <dc:Bounds x="180" y="96" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- Start_Representacao center (198, 184) -->
      <bpmndi:BPMNShape id="Start_Representacao_di" bpmnElement="Start_Representacao">
        <dc:Bounds x="180" y="166" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- Task_AberturaOuv   x=250  y=84   w=130 h=60 → center y=114 -->
      <bpmndi:BPMNShape id="Task_AberturaOuv_di" bpmnElement="Task_AberturaOuv">
        <dc:Bounds x="250" y="84" width="130" height="60" />
      </bpmndi:BPMNShape>
      <!-- Task_AberturaRep   x=250  y=154  w=130 h=60 → center y=184 -->
      <bpmndi:BPMNShape id="Task_AberturaRep_di" bpmnElement="Task_AberturaRep">
        <dc:Bounds x="250" y="154" width="130" height="60" />
      </bpmndi:BPMNShape>
      <!-- Gateway_Merge_OC   center (430, 149) -->
      <bpmndi:BPMNShape id="Gateway_Merge_OC_di" bpmnElement="Gateway_Merge_OC" isMarkerVisible="true">
        <dc:Bounds x="410" y="129" width="40" height="40" />
      </bpmndi:BPMNShape>
      <!-- Task_InstrucaoOC   x=480  y=119  w=130 h=60 → center y=149 -->
      <bpmndi:BPMNShape id="Task_InstrucaoOC_di" bpmnElement="Task_InstrucaoOC">
        <dc:Bounds x="480" y="119" width="130" height="60" />
      </bpmndi:BPMNShape>
      <!-- Task_AtualizaEpadOC x=640 y=119  w=130 h=60 → center y=149 -->
      <bpmndi:BPMNShape id="Task_AtualizaEpadOC_di" bpmnElement="Task_AtualizaEpadOC">
        <dc:Bounds x="640" y="119" width="130" height="60" />
      </bpmndi:BPMNShape>
      <!-- Gateway_To_Diaco   center (820, 149) -->
      <bpmndi:BPMNShape id="Gateway_To_Diaco_di" bpmnElement="Gateway_To_Diaco" isMarkerVisible="true">
        <dc:Bounds x="800" y="129" width="40" height="40" />
      </bpmndi:BPMNShape>

      <!-- ── Lane Diaco (y 230–400, center y=315) ── -->
      <!-- Task_Triagem           x=780  y=280  w=130 h=70 → center (845, 315) -->
      <bpmndi:BPMNShape id="Task_Triagem_di" bpmnElement="Task_Triagem">
        <dc:Bounds x="780" y="280" width="130" height="70" />
      </bpmndi:BPMNShape>
      <!-- Task_CoordDiaco        x=940  y=280  w=150 h=70 → center (1015, 315) -->
      <bpmndi:BPMNShape id="Task_CoordDiaco_di" bpmnElement="Task_CoordDiaco">
        <dc:Bounds x="940" y="280" width="150" height="70" />
      </bpmndi:BPMNShape>
      <!-- Task_ParecerAdm        x=1130 y=280  w=140 h=70 → center (1200, 315) -->
      <bpmndi:BPMNShape id="Task_ParecerAdm_di" bpmnElement="Task_ParecerAdm">
        <dc:Bounds x="1130" y="280" width="140" height="70" />
      </bpmndi:BPMNShape>
      <!-- Task_DeliberacaoDiaco  x=1410 y=280  w=150 h=70 → center (1485, 315) -->
      <bpmndi:BPMNShape id="Task_DeliberacaoDiaco_di" bpmnElement="Task_DeliberacaoDiaco">
        <dc:Bounds x="1410" y="280" width="150" height="70" />
      </bpmndi:BPMNShape>
      <!-- Gateway_Decision       center (1600, 315) -->
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true">
        <dc:Bounds x="1580" y="295" width="40" height="40" />
      </bpmndi:BPMNShape>
      <!-- End_Arquivado          center (1668, 315) -->
      <bpmndi:BPMNShape id="End_Arquivado_di" bpmnElement="End_Arquivado">
        <dc:Bounds x="1650" y="297" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ── Lane Subcorregedoria (y 400–560, center y=480) ── -->
      <!-- Task_AprovaINV   x=890  y=445  w=140 h=70 → center (960, 480) -->
      <bpmndi:BPMNShape id="Task_AprovaINV_di" bpmnElement="Task_AprovaINV">
        <dc:Bounds x="890" y="445" width="140" height="70" />
      </bpmndi:BPMNShape>
      <!-- Task_AprovaPAR   x=1250 y=445  w=140 h=70 → center (1320, 480) -->
      <bpmndi:BPMNShape id="Task_AprovaPAR_di" bpmnElement="Task_AprovaPAR">
        <dc:Bounds x="1250" y="445" width="140" height="70" />
      </bpmndi:BPMNShape>

      <!-- ── Lane Divid (y 560–930) ── -->

      <!-- Task_CoordDivid   x=200  y=630  w=130 h=70 → center (265, 665) -->
      <bpmndi:BPMNShape id="Task_CoordDivid_di" bpmnElement="Task_CoordDivid">
        <dc:Bounds x="200" y="630" width="130" height="70" />
      </bpmndi:BPMNShape>
      <!-- Gateway_Split_Inv center (380, 665) -->
      <bpmndi:BPMNShape id="Gateway_Split_Inv_di" bpmnElement="Gateway_Split_Inv" isMarkerVisible="true">
        <dc:Bounds x="360" y="645" width="40" height="40" />
      </bpmndi:BPMNShape>

      <!-- SubProcess_IPS  (colapsado) x=440 y=575 w=200 h=80 → linha 1, center (540, 615) -->
      <bpmndi:BPMNShape id="SubProcess_IPS_di" bpmnElement="SubProcess_IPS" isExpanded="false">
        <dc:Bounds x="440" y="575" width="200" height="80" />
      </bpmndi:BPMNShape>

      <!-- SubProcess_INPRE (colapsado) x=440 y=625 w=200 h=80 → linha 2, center (540, 665)
           Alinhado verticalmente com os gateways -->
      <bpmndi:BPMNShape id="SubProcess_INPRE_di" bpmnElement="SubProcess_INPRE" isExpanded="false">
        <dc:Bounds x="440" y="625" width="200" height="80" />
      </bpmndi:BPMNShape>

      <!-- Task_DINVE       x=440  y=715  w=200 h=70 → linha 3, center (540, 750) -->
      <bpmndi:BPMNShape id="Task_DINVE_di" bpmnElement="Task_DINVE">
        <dc:Bounds x="440" y="715" width="200" height="70" />
      </bpmndi:BPMNShape>

      <!-- Gateway_Join_Inv center (720, 665) — alinhado verticalmente com Split e INPRE -->
      <bpmndi:BPMNShape id="Gateway_Join_Inv_di" bpmnElement="Gateway_Join_Inv" isMarkerVisible="true">
        <dc:Bounds x="700" y="645" width="40" height="40" />
      </bpmndi:BPMNShape>

      <!-- Fluxo GenDivid (independente) — linha 4, y 855–925 -->
      <!-- Start_GenDivid   center (238, 873) -->
      <bpmndi:BPMNShape id="Start_GenDivid_di" bpmnElement="Start_GenDivid">
        <dc:Bounds x="220" y="855" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- Task_GerenDivid  x=280  y=840  w=180 h=70 → center (370, 875) -->
      <bpmndi:BPMNShape id="Task_GerenDivid_di" bpmnElement="Task_GerenDivid">
        <dc:Bounds x="280" y="840" width="180" height="70" />
      </bpmndi:BPMNShape>
      <!-- Task_AtdDemDivid x=490  y=840  w=180 h=70 → center (580, 875) -->
      <bpmndi:BPMNShape id="Task_AtdDemDivid_di" bpmnElement="Task_AtdDemDivid">
        <dc:Bounds x="490" y="840" width="180" height="70" />
      </bpmndi:BPMNShape>
      <!-- End_GenDivid     center (708, 873) -->
      <bpmndi:BPMNShape id="End_GenDivid_di" bpmnElement="End_GenDivid">
        <dc:Bounds x="690" y="855" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ── Lane DProc (y 930–1090, center y=1010) ── -->
      <!-- Task_InstauracaoPAR x=1580 y=975  w=140 h=70 → center (1650, 1010) -->
      <bpmndi:BPMNShape id="Task_InstauracaoPAR_di" bpmnElement="Task_InstauracaoPAR">
        <dc:Bounds x="1580" y="975" width="140" height="70" />
      </bpmndi:BPMNShape>
      <!-- Task_CoordDProc     x=1750 y=975  w=130 h=70 → center (1815, 1010) -->
      <bpmndi:BPMNShape id="Task_CoordDProc_di" bpmnElement="Task_CoordDProc">
        <dc:Bounds x="1750" y="975" width="130" height="70" />
      </bpmndi:BPMNShape>
      <!-- End_PAR             center (1933, 1010) -->
      <bpmndi:BPMNShape id="End_PAR_di" bpmnElement="End_PAR">
        <dc:Bounds x="1915" y="992" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ══ Edges ══ -->

      <!-- Flow_S1: (216,114) → (250,114) -->
      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="216" y="114" />
        <di:waypoint x="250" y="114" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S2: (216,184) → (250,184) -->
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="216" y="184" />
        <di:waypoint x="250" y="184" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S3: Task_AberturaOuv right (380,114) → Gateway top (430,129) -->
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="380" y="114" />
        <di:waypoint x="430" y="129" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S4: Task_AberturaRep right (380,184) → Gateway bottom (430,169) -->
      <bpmndi:BPMNEdge id="Flow_S4_di" bpmnElement="Flow_S4">
        <di:waypoint x="380" y="184" />
        <di:waypoint x="430" y="169" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S5: (450,149) → (480,149) -->
      <bpmndi:BPMNEdge id="Flow_S5_di" bpmnElement="Flow_S5">
        <di:waypoint x="450" y="149" />
        <di:waypoint x="480" y="149" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S6: (610,149) → (640,149) -->
      <bpmndi:BPMNEdge id="Flow_S6_di" bpmnElement="Flow_S6">
        <di:waypoint x="610" y="149" />
        <di:waypoint x="640" y="149" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S7: (770,149) → (800,149) -->
      <bpmndi:BPMNEdge id="Flow_S7_di" bpmnElement="Flow_S7">
        <di:waypoint x="770" y="149" />
        <di:waypoint x="800" y="149" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S8: Gateway_To_Diaco bottom (820,169) → Task_Triagem top (820,280) -->
      <bpmndi:BPMNEdge id="Flow_S8_di" bpmnElement="Flow_S8">
        <di:waypoint x="820" y="169" />
        <di:waypoint x="820" y="280" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S9: (910,315) → (940,315) -->
      <bpmndi:BPMNEdge id="Flow_S9_di" bpmnElement="Flow_S9">
        <di:waypoint x="910" y="315" />
        <di:waypoint x="940" y="315" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S10: CoordDiaco bottom (1015,350) → CoordDivid top (265,630)
           desce até y=545, vai para esquerda, entra pela parte superior -->
      <bpmndi:BPMNEdge id="Flow_S10_di" bpmnElement="Flow_S10">
        <di:waypoint x="1015" y="350" />
        <di:waypoint x="1015" y="545" />
        <di:waypoint x="265"  y="545" />
        <di:waypoint x="265"  y="630" />
      </bpmndi:BPMNEdge>

      <!-- Flow_S11: CoordDivid right (330,665) → Gateway_Split left (360,665) -->
      <bpmndi:BPMNEdge id="Flow_S11_di" bpmnElement="Flow_S11">
        <di:waypoint x="330" y="665" />
        <di:waypoint x="360" y="665" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_IPS: Split top (380,645) → SubProcess_IPS left (440,615) -->
      <bpmndi:BPMNEdge id="Flow_To_IPS_di" bpmnElement="Flow_To_IPS">
        <di:waypoint x="380" y="645" />
        <di:waypoint x="410" y="615" />
        <di:waypoint x="440" y="615" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_INPRE: Split right (400,665) → SubProcess_INPRE left (440,665) -->
      <bpmndi:BPMNEdge id="Flow_To_INPRE_di" bpmnElement="Flow_To_INPRE">
        <di:waypoint x="400" y="665" />
        <di:waypoint x="440" y="665" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_DINVE: Split bottom (380,685) → Task_DINVE left (440,750) -->
      <bpmndi:BPMNEdge id="Flow_To_DINVE_di" bpmnElement="Flow_To_DINVE">
        <di:waypoint x="380" y="685" />
        <di:waypoint x="410" y="750" />
        <di:waypoint x="440" y="750" />
      </bpmndi:BPMNEdge>

      <!-- Flow_From_IPS: SubProcess_IPS right (640,615) → Join top (720,645) -->
      <bpmndi:BPMNEdge id="Flow_From_IPS_di" bpmnElement="Flow_From_IPS">
        <di:waypoint x="640" y="615" />
        <di:waypoint x="680" y="615" />
        <di:waypoint x="720" y="645" />
      </bpmndi:BPMNEdge>

      <!-- Flow_From_INPRE: SubProcess_INPRE right (640,665) → Join left (700,665) -->
      <bpmndi:BPMNEdge id="Flow_From_INPRE_di" bpmnElement="Flow_From_INPRE">
        <di:waypoint x="640" y="665" />
        <di:waypoint x="700" y="665" />
      </bpmndi:BPMNEdge>

      <!-- Flow_From_DINVE: Task_DINVE right (640,750) → Join bottom (720,685) -->
      <bpmndi:BPMNEdge id="Flow_From_DINVE_di" bpmnElement="Flow_From_DINVE">
        <di:waypoint x="640" y="750" />
        <di:waypoint x="680" y="750" />
        <di:waypoint x="720" y="685" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_AprovaINV: Join top (720,645) → AprovaINV bottom (960,515)
           sobe pelo centro, entra pela base da task -->
      <bpmndi:BPMNEdge id="Flow_To_AprovaINV_di" bpmnElement="Flow_To_AprovaINV">
        <di:waypoint x="720" y="645" />
        <di:waypoint x="720" y="480" />
        <di:waypoint x="890" y="480" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_Parecer: AprovaINV right (1030,480) → ParecerAdm left (1130,315)
           vai para direita, sobe, entra pela esquerda -->
      <bpmndi:BPMNEdge id="Flow_To_Parecer_di" bpmnElement="Flow_To_Parecer">
        <di:waypoint x="1030" y="480" />
        <di:waypoint x="1080" y="480" />
        <di:waypoint x="1080" y="315" />
        <di:waypoint x="1130" y="315" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_AprovaPAR: ParecerAdm right (1270,315) → AprovaPAR top (1320,445) -->
      <bpmndi:BPMNEdge id="Flow_To_AprovaPAR_di" bpmnElement="Flow_To_AprovaPAR">
        <di:waypoint x="1270" y="315" />
        <di:waypoint x="1320" y="315" />
        <di:waypoint x="1320" y="445" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_Deliberacao: AprovaPAR right (1390,480) → DeliberacaoDiaco left (1410,315) -->
      <bpmndi:BPMNEdge id="Flow_To_Deliberacao_di" bpmnElement="Flow_To_Deliberacao">
        <di:waypoint x="1390" y="480" />
        <di:waypoint x="1400" y="480" />
        <di:waypoint x="1400" y="315" />
        <di:waypoint x="1410" y="315" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_Decision: (1560,315) → (1580,315) -->
      <bpmndi:BPMNEdge id="Flow_To_Decision_di" bpmnElement="Flow_To_Decision">
        <di:waypoint x="1560" y="315" />
        <di:waypoint x="1580" y="315" />
      </bpmndi:BPMNEdge>

      <!-- Flow_Decision_Arq: (1620,315) → (1650,315) -->
      <bpmndi:BPMNEdge id="Flow_Decision_Arq_di" bpmnElement="Flow_Decision_Arq">
        <di:waypoint x="1620" y="315" />
        <di:waypoint x="1650" y="315" />
      </bpmndi:BPMNEdge>

      <!-- Flow_Decision_PAR: Gateway_Decision bottom (1600,335) → InstauracaoPAR top (1650,975) -->
      <bpmndi:BPMNEdge id="Flow_Decision_PAR_di" bpmnElement="Flow_Decision_PAR">
        <di:waypoint x="1600" y="335" />
        <di:waypoint x="1600" y="1010" />
        <di:waypoint x="1580" y="1010" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_CoordDProc: (1720,1010) → (1750,1010) -->
      <bpmndi:BPMNEdge id="Flow_To_CoordDProc_di" bpmnElement="Flow_To_CoordDProc">
        <di:waypoint x="1720" y="1010" />
        <di:waypoint x="1750" y="1010" />
      </bpmndi:BPMNEdge>

      <!-- Flow_To_EndPAR: (1880,1010) → (1915,1010) -->
      <bpmndi:BPMNEdge id="Flow_To_EndPAR_di" bpmnElement="Flow_To_EndPAR">
        <di:waypoint x="1880" y="1010" />
        <di:waypoint x="1915" y="1010" />
      </bpmndi:BPMNEdge>

      <!-- GenDivid -->
      <bpmndi:BPMNEdge id="Flow_GD1_di" bpmnElement="Flow_GD1">
        <di:waypoint x="256" y="873" />
        <di:waypoint x="280" y="875" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GD2_di" bpmnElement="Flow_GD2">
        <di:waypoint x="460" y="875" />
        <di:waypoint x="490" y="875" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GD3_di" bpmnElement="Flow_GD3">
        <di:waypoint x="670" y="875" />
        <di:waypoint x="690" y="873" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
