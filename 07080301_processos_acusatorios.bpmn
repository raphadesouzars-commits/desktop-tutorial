      <!-- Lane SubcorrDProc elements -->
      <bpmndi:BPMNShape id="Start_Admissibilidade_di" bpmnElement="Start_Admissibilidade">
        <dc:Bounds x="180" y="107" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DespachoInstauracao_di" bpmnElement="Task_DespachoInstauracao">
